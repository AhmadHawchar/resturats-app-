# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored and must never be committed.

# Firebase configuration (from the Firebase console -> Project settings)
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com

# ImgBB image hosting (https://api.imgbb.com/)
IMGBB_API_KEY=your_imgbb_api_key

# Firestore document id of the platform owner that receives commissions
PLATFORM_OWNER_ID=your_platform_owner_uid
